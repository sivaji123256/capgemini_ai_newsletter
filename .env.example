DATABASE_URL=postgresql://user:password@host:5432/ai_news
OPENAI_API_KEY=your_openai_api_key

NEWSLETTER_FROM_EMAIL=sender@example.com
NEWSLETTER_FROM_NAME=Capgemini Weekly AI Pulse

# Choose one provider path.
# Microsoft Graph:
GRAPH_TENANT_ID=your_tenant_id
GRAPH_CLIENT_ID=your_client_id
GRAPH_CLIENT_SECRET=your_client_secret

# SMTP fallback:
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=app_password_or_smtp_password
SMTP_USE_TLS=true
